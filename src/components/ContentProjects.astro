---
interface Project {
    name: string;
    description: string;
    technologies: string[];
    category: 'AI/ML' | 'Data Platform' | 'Data Engineering' | 'Full Stack';
    impact?: string;
    link: {
        url?: string;
        target?: string;
        title?: string;
        buttonLabel?: string;
    };
};

// ── Hero: the single artifact that says "data platform engineer with AI skills" ──
// Personal project — labelled as such, no invented business impact.
const hero: Project = {
    name: 'Order Anomaly Detection Pipeline',
    description: 'A streaming pipeline that flags anomalous orders in real time using a multi-agent LLM workflow over vector-retrieved context. Kafka ingests order events; a LangGraph multi-agent graph reasons over similar historical cases pulled from pgvector, with Gemini in the loop for classification and explanation. Streaming + multi-agent orchestration + vector search in one production-shaped system.',
    technologies: ['Apache Kafka', 'LangGraph', 'Multi-Agent LLM', 'PostgreSQL / pgvector', 'Google Gemini', 'Real-Time Streaming'],
    category: 'AI/ML',
    impact: 'Personal project — end-to-end AI engineering: streaming, multi-agent orchestration, and vector search in a production-shaped system.',
    link: {
        // TODO: replace with the anomaly-pipeline repo URL.
        url: 'https://github.com/AmnaMunawar461/',
        buttonLabel: 'View on GitHub'
    }
};

// ── Flagship grid: 4 platform + 2 AI (+ hero AI above) = the curated shortlist ──
// Order = priority. Strongest platform card first, AI after.
const flagship: Project[] = [{
    name: 'Data Pipeline Migration & Optimization',
    description: 'Cut pipeline runtime 45% and infrastructure cost 25% by migrating legacy Spark workloads to dbt and autoscaling Trino clusters with KEDA — sustaining query performance under high concurrency.',
    technologies: ['dbt', 'Apache Spark', 'Trino', 'KEDA', 'Apache Airflow', 'AWS'],
    category: 'Data Platform',
    impact: '45% faster pipelines · 25% lower compute cost',
    link: { buttonLabel: 'View Details' }
}, {
    name: 'Production Database Infrastructure on Kubernetes',
    description: 'Ran zero-downtime, cross-account database migrations on CNPG (Cloud Native PostgreSQL) using AWS DMS over VPC PrivateLink, with Helm-managed deployments for production workloads.',
    technologies: ['CNPG', 'Kubernetes', 'AWS DMS', 'VPC PrivateLink', 'Helm', 'PostgreSQL'],
    category: 'Data Platform',
    impact: 'Zero-downtime production migrations',
    link: { buttonLabel: 'View Details' }
}, {
    name: 'Production Data Recovery & CDC',
    description: 'Recovered critical order data from S3 snapshots within 2 hours to prevent business disruption, and built Debezium change-data-capture over MySQL and MongoDB streaming into Kafka for real-time synchronization.',
    technologies: ['Debezium', 'Apache Kafka', 'MySQL', 'MongoDB', 'AWS S3', 'Helm'],
    category: 'Data Platform',
    impact: '2-hour critical recovery · real-time CDC streaming',
    link: { buttonLabel: 'View Details' }
}, {
    name: 'MongoDB Archiving & Cost Optimization',
    description: 'Reduced storage and read I/O cost 30% by archiving 65M+ documents from large MongoDB collections to S3 with automated lifecycle management and retrieval.',
    technologies: ['MongoDB', 'AWS S3', 'Lifecycle Management', 'Python', 'Cost Optimization'],
    category: 'Data Platform',
    impact: '30% storage & I/O cost reduction · 65M+ docs archived',
    link: { buttonLabel: 'View Details' }
}, {
    name: 'LLM-Powered Search Query Suggestions',
    description: 'Shipped a production query-suggestion system using Google Gemini and LangChain, with LLM-based relevance classification that improves live search quality — tuned through prompt engineering.',
    technologies: ['Google Gemini API', 'LangChain', 'Python', 'Prompt Engineering', 'LLM'],
    category: 'AI/ML',
    impact: 'Live search quality improved in production',
    link: { buttonLabel: 'View Details' }
}, {
    name: 'AI Recommendation System',
    description: 'Built an ALS collaborative-filtering recommendation model and served it through the existing microservices architecture for region-aware product personalization.',
    technologies: ['Python', 'Scikit-learn', 'ALS', 'Spring Boot', 'PostgreSQL', 'Microservices'],
    category: 'AI/ML',
    impact: 'Region-aware personalization in production',
    link: { buttonLabel: 'View Details' }
}];

// ── One full-stack proof for the "also full-stack capable" line ──
const fullStack: Project = {
    name: 'Invoice Management System',
    description: 'End-to-end invoice management with a React/TypeScript frontend and Kotlin/Spring Boot backend — 50% API latency reduction and 100% test coverage via TDD.',
    technologies: ['React.js', 'TypeScript', 'Kotlin', 'Spring Boot', 'PostgreSQL', 'TDD'],
    category: 'Full Stack',
    impact: '50% API latency reduction · 100% test coverage',
    link: { buttonLabel: 'View Details' }
};

// ── Additional production work (compact, not headline cards) ──
// Two Apache Ranger entries merged into one governance line.
const moreProduction = [
    { name: 'Data Governance (Apache Ranger)', detail: 'Centralized access control, data masking, and role-based policies on Kubernetes via Terraform, with automated user provisioning.' },
    { name: 'Real-Time Pipeline for Customer Support', detail: 'TimescaleDB on CNPG with real-time aggregates feeding chatbot order/voucher lookups — 35% query performance improvement.' },
    { name: 'Database Monitoring & Alerting', detail: 'Percona monitoring for RDS/PostgreSQL with automated alerts and dashboards for proactive reliability.' },
    { name: 'RFM Customer Segmentation', detail: 'RFM models and behavioral pipelines powering marketing segmentation and user targeting.' }
];

// ── Side projects (learning builds) — collapsed, GitHub-only ──
const sideProjects = [
    { name: 'RAG Medical Q/A Chatbot', tech: 'LangChain · FAISS · OpenAI', url: '' },
    { name: 'Babel Fish (LLM STT/TTS Translator)', tech: 'LLMs · Speech-to-Text · TTS', url: 'https://github.com/AmnaMunawar461/Babel-Fish-with-LLM-STT-TTS' },
    { name: 'Business AI Meeting Companion', tech: 'Speech-to-Text · NLP', url: 'https://github.com/AmnaMunawar461/Business-AI-Meeting-Companion-STT' },
    { name: 'CV-to-Job Description Matching', tech: 'NLP · Similarity Scoring', url: 'https://github.com/AmnaMunawar461/Matching-CV-to-Job-Description' },
    { name: 'Personalized Job Application Coach', tech: 'LLMs · Personalization', url: 'https://github.com/AmnaMunawar461/Your-Personalized-Job-Application-Coach-Based-on-LLM' },
    { name: 'Voice Assistant', tech: 'Speech Recognition · NLP', url: 'https://github.com/AmnaMunawar461/VoiceAssistant' }
];
---

<div>

    <div class="mb-6">
        <h2 class="text-2xl font-bold text-white mb-2">Featured Projects</h2>
        <p class="text-gray-400 text-sm">Data Platform &amp; AI work, production-first — curated, not exhaustive.</p>
    </div>

    <!-- Start: Hero project -->
    <div class="mb-8 border border-primary/60 rounded-lg p-6 bg-gradient-to-br from-primary/10 to-black hover:border-primary transition-colors">
        <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="text-xs px-2 py-1 rounded bg-primary text-white font-semibold uppercase tracking-wide">★ Hero Project</span>
            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-300 border border-gray-700">Personal Project</span>
            <span class="text-xs px-2 py-1 rounded bg-primary/20 text-primary border border-primary/30">{hero.category}</span>
        </div>

        <h3 class="text-2xl font-semibold text-white mb-3">{hero.name}</h3>

        <p class="text-gray-300 text-sm mb-4 leading-relaxed">{hero.description}</p>

        {hero.impact ? (
            <div class="mb-4 p-2 bg-black/40 rounded border-l-2 border-primary">
                <p class="text-xs text-gray-300">{hero.impact}</p>
            </div>
        ) : null}

        <div class="flex flex-wrap gap-2 mb-4">
            {hero.technologies.map(tech => (
                <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-300 border border-gray-700">{tech}</span>
            ))}
        </div>

        {hero.link?.url ? (
            <a
                href={hero.link.url}
                title={hero.name}
                target="_blank"
                class="inline-block px-5 py-2.5 text-center border border-primary rounded-lg text-primary hover:bg-primary hover:text-white transition-colors">
                {hero.link.buttonLabel || 'View Project'}
            </a>
        ) : null}
    </div>
    <!-- End: Hero project -->

    <!-- Start: Flagship grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {flagship.map(project =>

            <div class="flex flex-col justify-between items-start border border-gray-700 rounded-lg p-5 bg-black hover:border-primary transition-colors">

                <div class="w-full">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs px-2 py-1 rounded bg-primary/20 text-primary border border-primary/30">
                            {project.category}
                        </span>
                    </div>

                    <h3 class="text-xl font-semibold text-white mb-3">
                    {project.name}
                </h3>

                    <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                    {project.description}
                </p>

                    {project.impact ? (
                        <div class="mb-4 p-2 bg-gray-900/50 rounded border-l-2 border-primary">
                            <p class="text-xs text-primary font-semibold mb-1">Impact</p>
                            <p class="text-xs text-gray-300">{project.impact}</p>
                        </div>
                    ) : null}

                    <div class="flex flex-wrap gap-2 mb-4">
                        {project.technologies.slice(0, 4).map(tech => (
                            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-300 border border-gray-700">
                                {tech}
                            </span>
                        ))}
                        {project.technologies.length > 4 ? (
                            <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-400 border border-gray-700">
                                +{project.technologies.length - 4} more
                            </span>
                        ) : null}
                    </div>
                </div>

                {
                    project.link?.url ?
                        <a
                            href={project.link.url}
                            title={project.link.title || project.name}
                            target={project.link.target || '_blank'}
                            class="
                                w-full px-4 py-2.5 mt-auto text-center
                                border border-gray-600 rounded-lg
                                hover:text-primary
                                hover:border-primary
                                transition-colors
                            ">
                            {project.link.buttonLabel || 'View Project'}
                        </a>
                    : project.link?.buttonLabel ?
                        <div class="w-full px-4 py-2.5 mt-auto text-center border border-gray-600 rounded-lg text-gray-500 cursor-not-allowed">
                            {project.link.buttonLabel}
                        </div>
                    : null
                }

            </div>

        )}

    </div>
    <!-- End: Flagship grid -->

    <!-- Start: Also full-stack -->
    <div class="mt-10">
        <h3 class="text-lg font-bold text-white mb-1">Also full-stack capable</h3>
        <p class="text-gray-400 text-xs mb-4">One representative full-stack build — frontend through backend, with the metrics to back it.</p>

        <div class="border border-gray-700 rounded-lg p-5 bg-black hover:border-primary transition-colors">
            <span class="text-xs px-2 py-1 rounded bg-primary/20 text-primary border border-primary/30">{fullStack.category}</span>
            <h4 class="text-lg font-semibold text-white mt-2 mb-2">{fullStack.name}</h4>
            <p class="text-gray-400 text-sm mb-3 leading-relaxed">{fullStack.description}</p>
            {fullStack.impact ? (
                <div class="mb-3 p-2 bg-gray-900/50 rounded border-l-2 border-primary">
                    <p class="text-xs text-gray-300">{fullStack.impact}</p>
                </div>
            ) : null}
            <div class="flex flex-wrap gap-2">
                {fullStack.technologies.map(tech => (
                    <span class="text-xs px-2 py-1 rounded bg-gray-800 text-gray-300 border border-gray-700">{tech}</span>
                ))}
            </div>
        </div>
    </div>
    <!-- End: Also full-stack -->

    <!-- Start: More production work -->
    <div class="mt-10">
        <h3 class="text-lg font-bold text-white mb-3">More production work</h3>
        <ul class="space-y-2">
            {moreProduction.map(item => (
                <li class="text-sm text-gray-400 border-l-2 border-gray-700 pl-3">
                    <span class="text-gray-200 font-semibold">{item.name}</span> — {item.detail}
                </li>
            ))}
        </ul>
    </div>
    <!-- End: More production work -->

    <!-- Start: Side projects (collapsed) -->
    <details class="mt-10 border border-gray-800 rounded-lg p-4 bg-black">
        <summary class="cursor-pointer text-sm text-gray-300 hover:text-primary select-none">
            Side projects &amp; learning builds ({sideProjects.length}) — click to expand
        </summary>
        <ul class="mt-4 space-y-2">
            {sideProjects.map(sp => (
                <li class="flex flex-wrap items-center justify-between gap-2 text-sm">
                    <span>
                        <span class="text-gray-200">{sp.name}</span>
                        <span class="text-gray-500 text-xs"> · {sp.tech}</span>
                    </span>
                    {sp.url ? (
                        <a href={sp.url} target="_blank" title={sp.name} class="text-xs text-primary hover:underline">GitHub →</a>
                    ) : null}
                </li>
            ))}
        </ul>
    </details>
    <!-- End: Side projects -->

</div>

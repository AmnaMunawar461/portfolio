---
import { Picture } from 'astro:assets';
import ProfilePicture from '../assets/profile.png';

const profile = {
    name: 'Amna Munawar',
    title: 'Senior Data Platform & AI Engineer',
    tagline: 'Production data infrastructure at scale · LLM systems shipped to real products',
    location: 'Pakistan',
    description: 'Senior Data Platform Engineer with 3.5+ years building and operating production data infrastructure — streaming pipelines, lakehouse, and Kubernetes-native databases processing 50M+ records daily. I take AI from prototype to production (RAG, multi-agent orchestration, recommendation engines) and have delivered 45% faster pipelines, 30% lower infra cost, and zero-downtime migrations. Comfortable full-stack (React, Kotlin, Spring Boot) when a platform needs a front door.'
};

// Drop your résumé PDF at /public/resume.pdf for this button to resolve.
const resumeUrl = '/Amna Munawar Data Engineer.pdf';
const emailUrl  = 'mailto:amnamunawar2201@gmail.com';
---

<div class="flex flex-col gap-6 items-center text-center sm:items-start sm:text-left">

    <div class="flex flex-col sm:flex-row gap-4 sm:items-center">

        <Picture
            src={ProfilePicture}
            formats={['webp']}
            width={128}
            height={128}
            alt={'Profile picture ' + profile.name}
            title={profile.name}
            class="w-32 h-32 rounded-xl object-cover border-2 border-primary mx-auto sm:mx-0"
        />

        <div>

            <h1 class="text-2xl font-extrabold mb-1 inline-block relative text-text-primary">
                {profile.name}
            </h1>

            <p class="text-sm mb-1 text-primary font-semibold">
                {profile.title}
            </p>

            <p class="text-xs mb-2 text-gray-400 leading-snug">
                {profile.tagline}
            </p>

            <p class="flex items-center justify-center sm:justify-start text-sm text-gray-400">
                <svg class="-mt-0.5 inline mr-2"fill=none height=14 stroke=currentColor stroke-linecap=round stroke-linejoin=round stroke-width=2 viewBox="0 0 24 24"width=14 xmlns=http://www.w3.org/2000/svg><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx=12 cy=10 r=3></circle></svg>
                {profile.location}
            </p>

        </div>

    </div>

    <p class="text-sm leading-relaxed mt-2 text-gray-400">
        {profile.description}
    </p>

    <!-- Start: Primary CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 w-full">

        <a
            href={resumeUrl}
            target="_blank"
            title="Download résumé (PDF)"
            class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-center rounded-lg bg-primary text-white hover:opacity-90 transition-opacity">
            <svg fill=none height=16 stroke=currentColor stroke-linecap=round stroke-linejoin=round stroke-width=2 viewBox="0 0 24 24" width=16 xmlns=http://www.w3.org/2000/svg><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1=12 x2=12 y1=15 y2=3></line></svg>
            Download Résumé
        </a>

        <a
            href={emailUrl}
            title="Email Amna"
            class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-center rounded-lg border border-gray-600 text-gray-200 hover:text-primary hover:border-primary transition-colors">
            <svg fill=none height=16 stroke=currentColor stroke-linecap=round stroke-linejoin=round stroke-width=2 viewBox="0 0 24 24" width=16 xmlns=http://www.w3.org/2000/svg><rect height=16 rx=2 width=20 x=2 y=4></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            Get in Touch
        </a>

    </div>
    <!-- End: Primary CTAs -->

</div>